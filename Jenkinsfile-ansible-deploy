pipeline {
    agent any

    environment {
        ANSIBLE_HOST_KEY_CHECKING = 'False'
        GCP_BUCKET = 'flooid-test'
        WAR_FILE = 'orders.war'
        INVENTORY = 'ansible/inventory-orders.ini'
        PLAYBOOK = 'ansible/playbooks/tomcat.yml'
        APP_URL = 'http://34.121.100.196:8080/orders/'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify tools') {
            steps {
                sh '''
                    set -e
                    which ansible
                    ansible --version
                    which gcloud
                    gcloud --version
                    which curl
                    curl --version | head -n 1
                '''
            }
        }

        stage('Verify WAR in GCS') {
            steps {
                sh '''
                    set -e
                    gcloud storage ls gs://${GCP_BUCKET}/${WAR_FILE}
                '''
            }
        }

        stage('Deploy with Ansible') {
            steps {
                sh '''
                    set -e
                    ansible-playbook -i ${INVENTORY} ${PLAYBOOK} -b
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    set -e

                    for i in $(seq 1 12); do
                      echo "Health check attempt $i..."

                      if ansible -i ${INVENTORY} app -b -a "curl -I --max-time 10 http://localhost:8080/orders/"; then
                        echo "Application is healthy on target host."
                        exit 0
                      fi

                      echo "App not ready yet. Waiting 10 seconds..."
                      sleep 10
                    done

                    echo "Application did not become healthy in time."
                    exit 1
                '''
            }
        }
    }

    post {
        success {
            echo 'Orders deployment completed successfully.'
        }
        failure {
            echo 'Orders deployment failed.'
        }
    }
}
