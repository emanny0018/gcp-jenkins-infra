pipeline {
  agent any

  options {
    timestamps()
    timeout(time: 20, unit: 'MINUTES')
  }

  parameters {
    choice(name: 'SERVICE',
           choices: ['orders', 'payments', 'users', 'inventory', 'gateway'],
           description: 'Which service MIG to operate')

    choice(name: 'MODE',
           choices: ['autoscaler_on', 'autoscaler_off_manual'],
           description: 'Enable autoscaler OR delete it and use manual size')

    string(name: 'REGION', defaultValue: 'us-central1',
           description: 'Region of the regional MIG')

    // Autoscaler mode
    string(name: 'MIN', defaultValue: '1',
           description: 'Autoscaler min replicas')
    string(name: 'MAX', defaultValue: '3',
           description: 'Autoscaler max replicas')

    // Manual mode
    string(name: 'SIZE', defaultValue: '2',
           description: 'Manual MIG size when autoscaler is OFF')

    booleanParam(name: 'WAIT_STABLE', defaultValue: true,
                 description: 'Wait until MIG is stable at the end')
  }

  environment {
    TF_DIR = "terraform"
  }

  stages {

    stage('Read Terraform outputs') {
      steps {
        dir("${env.TF_DIR}") {
          sh '''
            set -eu
            terraform init -input=false
            terraform output -json > tf_outputs.json
          '''
        }
      }
    }

    stage('Resolve MIG name') {
      steps {
        dir("${env.TF_DIR}") {
          script {
            def mig = sh(
              script: """
                python3 - <<'PY'
import json
svc = "${params.SERVICE}"
with open("tf_outputs.json") as f:
    out = json.load(f)
print(out["mig_names"]["value"][svc])
PY
              """,
              returnStdout: true
            ).trim()

            env.MIG_NAME = mig
            env.REGION   = params.REGION
            env.MIN      = params.MIN
            env.MAX      = params.MAX
            env.SIZE     = params.SIZE

            echo "SERVICE  = ${params.SERVICE}"
            echo "MODE     = ${params.MODE}"
            echo "REGION   = ${env.REGION}"
            echo "MIG_NAME = ${env.MIG_NAME}"
          }
        }
      }
    }

    stage('Check autoscaler existence') {
      steps {
        script {
          def exists = sh(
            script: """
              set +e
              gcloud compute instance-groups managed describe "${env.MIG_NAME}" \
                --region "${env.REGION}" \
                --format="value(autoscaler)"
            """,
            returnStdout: true
          ).trim()

          if (exists) {
            env.AUTOSCALER_EXISTS = "true"
            echo "Autoscaler exists."
          } else {
            env.AUTOSCALER_EXISTS = "false"
            echo "Autoscaler does NOT exist."
          }
        }
      }
    }

    stage('Autoscaler ON') {
      when { expression { params.MODE == 'autoscaler_on' } }
      steps {
        sh '''
          set -eu
          echo "Applying autoscaler: min=${MIN} max=${MAX}"

          gcloud compute instance-groups managed set-autoscaling "${MIG_NAME}" \
            --region "${REGION}" \
            --min-num-replicas "${MIN}" \
            --max-num-replicas "${MAX}" \
            --cool-down-period 60 \
            --target-cpu-utilization 0.6
        '''
      }
    }

    stage('Autoscaler OFF + Manual Resize') {
      when { expression { params.MODE == 'autoscaler_off_manual' } }
      steps {
        sh '''
          set -eu

          if gcloud compute instance-groups managed describe "${MIG_NAME}" \
              --region "${REGION}" \
              --format="value(autoscaler)" | grep -q .; then

            echo "Deleting autoscaler..."
            AUTOSCALER_NAME=$(gcloud compute instance-groups managed describe "${MIG_NAME}" \
              --region "${REGION}" \
              --format="value(autoscaler.basename())")

            gcloud compute autoscalers delete "${AUTOSCALER_NAME}" \
              --region "${REGION}" \
              --quiet
          else
            echo "No autoscaler to delete."
          fi

          echo "Resizing MIG to ${SIZE}..."
          gcloud compute instance-groups managed resize "${MIG_NAME}" \
            --region "${REGION}" \
            --size "${SIZE}"
        '''
      }
    }

    stage('Wait Until Stable') {
      when { expression { return params.WAIT_STABLE } }
      steps {
        sh '''
          set -eu
          echo "Waiting for MIG to become stable..."
          gcloud compute instance-groups managed wait-until "${MIG_NAME}" \
            --region "${REGION}" \
            --stable
        '''
      }
    }

    stage('Final Verify') {
      steps {
        sh '''
          set -eu
          echo "=== FINAL STATUS ==="

          echo "Autoscaler:"
          gcloud compute instance-groups managed describe "${MIG_NAME}" \
            --region "${REGION}" \
            --format="yaml(autoscaler)"

          echo "Target Size:"
          gcloud compute instance-groups managed describe "${MIG_NAME}" \
            --region "${REGION}" \
            --format="value(targetSize)"
        '''
      }
    }
  }
}
