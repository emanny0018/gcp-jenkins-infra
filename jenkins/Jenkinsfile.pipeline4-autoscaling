pipeline {
  agent any

  options {
    timestamps()
    timeout(time: 20, unit: 'MINUTES')
  }

  parameters {
    choice(name: 'SERVICE', choices: ['orders', 'payments', 'users', 'inventory', 'gateway'],
           description: 'Which service MIG to operate')
    choice(name: 'MODE', choices: ['autoscaler_on', 'autoscaler_off_manual'],
           description: 'Keep autoscaler ON (edit min/max) OR turn it OFF and set manual size')
    string(name: 'REGION', defaultValue: 'us-central1', description: 'Region of the regional MIG')

    // For autoscaler_on
    string(name: 'MIN', defaultValue: '1', description: 'Autoscaler min replicas (MODE=autoscaler_on)')
    string(name: 'MAX', defaultValue: '3', description: 'Autoscaler max replicas (MODE=autoscaler_on)')

    // For autoscaler_off_manual
    string(name: 'SIZE', defaultValue: '2', description: 'Manual MIG size (MODE=autoscaler_off_manual)')

    booleanParam(name: 'WAIT_STABLE', defaultValue: true, description: 'Wait until MIG is stable at the end')
  }

  environment {
    TF_DIR = "terraform"
  }

  stages {
    stage('Read Terraform outputs') {
      steps {
        dir("${env.TF_DIR}") {
          sh '''
            set -eu
            terraform init -input=false
            terraform output -json > tf_outputs.json
          '''
        }
      }
    }

    stage('Resolve targets') {
      steps {
        dir("${env.TF_DIR}") {
          script {
            def mig = sh(
              script: """
                python3 - <<'PY'
import json
svc = "${params.SERVICE}"
with open("tf_outputs.json") as f:
    out = json.load(f)
print(out["mig_names"]["value"][svc])
PY
              """,
              returnStdout: true
            ).trim()

            env.MIG_NAME = mig
            // export params so /bin/sh can read them safely (set -u)
            env.SERVICE = params.SERVICE
            env.REGION  = params.REGION
            env.MIN     = params.MIN
            env.MAX     = params.MAX
            env.SIZE    = params.SIZE

            echo "SERVICE  = ${params.SERVICE}"
            echo "MODE     = ${params.MODE}"
            echo "REGION   = ${params.REGION}"
            echo "MIG_NAME = ${env.MIG_NAME}"
          }
        }
      }
    }

    stage('Autoscaler ON: set min/max') {
      when { expression { params.MODE == 'autoscaler_on' } }
      steps {
        sh '''
          set -eu
          echo "Setting autoscaler min=${MIN} max=${MAX} for ${MIG_NAME}..."
          gcloud compute autoscalers update "${SERVICE}-as" \
            --region "${REGION}" \
            --min-num-replicas "${MIN}" \
            --max-num-replicas "${MAX}" \
            --mode on
        '''
      }
    }

    stage('Autoscaler OFF: manual size') {
      when { expression { params.MODE == 'autoscaler_off_manual' } }
      steps {
        sh '''
          set -eu
          echo "Turning autoscaler OFF for ${MIG_NAME}-as..."
          gcloud compute autoscalers update "${SERVICE}-as" \
            --region "${REGION}" \
            --mode off

          echo "Resizing MIG to fixed size=${SIZE}..."
          gcloud compute instance-groups managed resize "${SERVICE}" \
            --region "${REGION}" \
            --size "${SIZE}"
        '''
      }
    }

    stage('Wait until stable') {
      when { expression { return params.WAIT_STABLE } }
      steps {
        sh '''
          set -eu
          echo "Waiting for MIG to become stable..."
          gcloud compute instance-groups managed wait-until "${MIG_NAME}" \
            --region "${REGION}" \
            --stable
        '''
      }
    }

    stage('Verify') {
      steps {
        sh '''
          set -eu
          echo "Autoscaler:"
          gcloud compute autoscalers describe "${SERVICE}-as" --region "${REGION}" \
            --format="yaml(autoscalingPolicy,status)"

          echo "MIG size:"
          gcloud compute instance-groups managed describe "${SERVICE}" --region "${REGION}" \
            --format="value(targetSize)"
        '''
      }
    }
  }
}
