pipeline {
  agent any

  options {
    timestamps()
    timeout(time: 20, unit: 'MINUTES')
  }

  parameters {
    choice(name: 'SERVICE',
           choices: ['orders', 'payments', 'users', 'inventory', 'gateway'],
           description: 'Which service MIG to operate')

    choice(name: 'MODE',
           choices: ['autoscaler_on', 'autoscaler_off'],
           description: 'Enable autoscaler OR disable it (freeze current size)')

    string(name: 'REGION', defaultValue: 'us-central1',
           description: 'Region of the regional MIG')

    string(name: 'MIN', defaultValue: '1',
           description: 'Autoscaler min replicas (used only when MODE=autoscaler_on)')

    string(name: 'MAX', defaultValue: '3',
           description: 'Autoscaler max replicas (used only when MODE=autoscaler_on)')

    booleanParam(name: 'WAIT_STABLE', defaultValue: true,
                 description: 'Wait until MIG is stable at the end')
  }

  environment {
    TF_DIR = "terraform"
  }

  stages {

    stage('Read Terraform outputs') {
      steps {
        dir("${env.TF_DIR}") {
          sh '''
            set -eu
            terraform init -input=false
            terraform output -json > tf_outputs.json
          '''
        }
      }
    }

    stage('Resolve MIG name') {
      steps {
        dir("${env.TF_DIR}") {
          script {
            def mig = sh(
              script: """
                python3 - <<'PY'
import json
svc = "${params.SERVICE}"
with open("tf_outputs.json") as f:
    out = json.load(f)
print(out["mig_names"]["value"][svc])
PY
              """,
              returnStdout: true
            ).trim()

            env.MIG_NAME = mig
            env.REGION   = params.REGION
            env.MIN      = params.MIN
            env.MAX      = params.MAX

            echo "SERVICE  = ${params.SERVICE}"
            echo "MODE     = ${params.MODE}"
            echo "REGION   = ${env.REGION}"
            echo "MIG_NAME = ${env.MIG_NAME}"
          }
        }
      }
    }

    stage('Autoscaler ON (Dynamic Scaling)') {
      when { expression { params.MODE == 'autoscaler_on' } }
      steps {
        sh '''
          set -eu
          echo "Enabling autoscaling: min=${MIN} max=${MAX}"

          gcloud compute instance-groups managed set-autoscaling "${MIG_NAME}" \
            --region "${REGION}" \
            --min-num-replicas "${MIN}" \
            --max-num-replicas "${MAX}" \
            --cool-down-period 60 \
            --target-cpu-utilization 0.6
        '''
      }
    }

    stage('Autoscaler OFF (Freeze Current Size)') {
      when { expression { params.MODE == 'autoscaler_off' } }
      steps {
        sh '''
          set -eu

          echo "Checking for existing autoscaler..."

          if gcloud compute instance-groups managed describe "${MIG_NAME}" \
               --region "${REGION}" \
               --format="value(autoscaler)" | grep -q .; then

            echo "Disabling autoscaling (capacity will remain unchanged)..."
            gcloud compute instance-groups managed delete-autoscaling "${MIG_NAME}" \
              --region "${REGION}" \
              --quiet
          else
            echo "No autoscaler attached."
          fi

          echo "Autoscaler disabled. MIG size remains as-is."
        '''
      }
    }

    stage('Wait Until Stable') {
      when { expression { return params.WAIT_STABLE } }
      steps {
        sh '''
          set -eu
          echo "Waiting for MIG to become stable..."
          gcloud compute instance-groups managed wait-until "${MIG_NAME}" \
            --region "${REGION}" \
            --stable
        '''
      }
    }

    stage('Final Verify') {
      steps {
        sh '''
          set -eu
          echo "=== FINAL STATUS ==="

          echo "Autoscaler:"
          gcloud compute instance-groups managed describe "${MIG_NAME}" \
            --region "${REGION}" \
            --format="yaml(autoscaler)"

          echo "Target Size:"
          gcloud compute instance-groups managed describe "${MIG_NAME}" \
            --region "${REGION}" \
            --format="value(targetSize)"
        '''
      }
    }
  }
}
